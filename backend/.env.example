PORT=3001
MONGO_URI=mongodb://localhost:27017/tutormecatronica
JWT_SECRET=replace_with_a_long_secret_of_24_or_more_chars
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins in production
# Example: https://tuvir-frontend.up.railway.app,https://tuvir-web.com
CORS_ORIGINS=

# Optional aliases still supported
CORS_ALLOWED_ORIGINS=
APP_URL=
FRONTEND_PUBLIC_URL=
BACKEND_PUBLIC_URL=

# AI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mail (optional)
MAIL_PROVIDER=resend
RESEND_API_KEY=
MAIL_SERVICE=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=
MAIL_PASS=
MAILPASS=
MAIL_FROM=
MAIL_REPLY_TO=
MAIL_TEST_TO=
MAIL_DEBUG_TOKEN=
MAIL_DEBUG_ENABLED=false
MAIL_TLS_REJECT_UNAUTHORIZED=true
