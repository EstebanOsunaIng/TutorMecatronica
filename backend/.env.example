# Backend environment variables
# Copy this file to `backend/.env` and fill in values

PORT=3001

# Public URLs for links and redirects
BACKEND_PUBLIC_URL=
FRONTEND_PUBLIC_URL=
INSTITUTIONAL_EMAIL_DOMAINS=gmail.com,hotmail.com,outlook.com,yahoo.com,live.com,icloud.com

# MongoDB Atlas or local
# If your network blocks SRV lookups, prefer a standard mongodb:// URI instead of mongodb+srv://
MONGO_URI=

JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_SECRET=

MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@tutormecatronica.com

# AI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# News (optional)
GNEWS_API_KEY=
# Optional alias used by some deployments
GNEWS_TOKEN=
NEWSAPI_KEY=
GNEWS_LANG=all
NEWS_TRANSLATE_URL=https://libretranslate.de/translate
NEWS_TRANSLATE_API_KEY=
