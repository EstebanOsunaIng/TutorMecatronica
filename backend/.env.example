# Backend environment variables
# Copy to `.env` and fill in values

PORT=3001
# MongoDB Atlas or local
# If your network blocks SRV lookups, prefer a standard mongodb:// URI instead of mongodb+srv://
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@tutormecatronica.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GNEWS_API_KEY=
GNEWS_LANG=all
NEWS_TRANSLATE_URL=https://libretranslate.de/translate
NEWS_TRANSLATE_API_KEY=
