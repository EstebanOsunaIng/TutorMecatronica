PORT=3001
MONGO_URI=mongodb://localhost:27017/tutormecatronica
JWT_SECRET=replace_with_a_long_secret_of_24_or_more_chars
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins in production
# Example: https://tuvir-frontend.up.railway.app,https://tuvir-web.com
CORS_ORIGINS=

# Optional aliases still supported
CORS_ALLOWED_ORIGINS=
FRONTEND_PUBLIC_URL=

# AI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mail (optional)
MAIL_SERVICE=
MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@tutormecatronica.com
